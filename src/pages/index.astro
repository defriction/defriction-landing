---
import Layout from '../layout/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import Process from '../components/Process.astro';
import Metrics from '../components/Metrics.astro';
import CaseStudies from '../components/CaseStudies.astro';
import FooterCTA from '../components/FooterCTA.astro';
import Footer from '../components/Footer.astro';
import Contact from '../components/Contact.astro';
import Products from '../components/Products.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import { ui } from '../i18n/ui';

const lang = 'en';
const t = ui[lang].meta;
---

<Layout title={t.title} description={t.description} lang={lang}>
    <Navbar lang={lang} />
    <Hero lang={lang} />
    <Products lang={lang} />
    <Services lang={lang} />
    <Process lang={lang} />
    <Metrics lang={lang} />
    <CaseStudies lang={lang} />
    <Testimonials lang={lang} />
    <FAQ lang={lang} />
    <Contact lang={lang} />
    <FooterCTA lang={lang} />
    <Footer lang={lang} />
</Layout>
