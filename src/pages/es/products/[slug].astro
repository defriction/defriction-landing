---
import Layout from '../../../layout/Layout.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
import ProductDetail from '../../../components/ProductDetail.astro';
import { getSortedProducts } from '../../../lib/products';

export async function getStaticPaths() {
  const products = await getSortedProducts();
  return products.map((product) => ({
    params: { slug: product.data.slug },
    props: { product },
  }));
}

const lang = 'es';
const { product } = Astro.props;
const { data } = product;

const title = `${data.name[lang]} — defriction`;
const description = data.hero.subtitle[lang];
const alternates = { en: `/products/${data.slug}`, es: `/es/products/${data.slug}` };
---

<Layout title={title} description={description} lang={lang} ogImage={data.image?.src} alternates={alternates}>
  <Navbar lang={lang} />
  <ProductDetail product={product} lang={lang} />
  <Footer lang={lang} />
</Layout>
