---
import { ui, BOOKING_URL } from '../i18n/ui';
const { lang = 'en' } = Astro.props;
const t = ui[lang as keyof typeof ui].hero;
---
<section class="relative pt-20 pb-32 overflow-hidden">
    <!-- Background Blobs -->
    <div class="blob-bg top-[-100px] left-[-100px] bg-[radial-gradient(circle,_rgba(152,255,152,0.2)_0%,_rgba(255,255,255,0)_70%)]"></div>
    <div class="blob-bg top-[20%] right-[-100px] bg-[radial-gradient(circle,_rgba(71,180,235,0.15)_0%,_rgba(255,255,255,0)_70%)]"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
            <!-- Text Content -->
            <div class="flex flex-col gap-6 text-center lg:text-left">
                <div class="inline-flex items-center gap-2 self-center lg:self-start px-3 py-1 rounded-full bg-gradient-to-r from-accent/10 to-primary/10 border border-accent/30 text-xs font-semibold text-gray-600">
                    <span class="size-2 rounded-full bg-accent animate-pulse"></span>
                    {t.badge}
                </div>
                <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight leading-[1.1] text-text-main dark:text-white">
                    {t.titleStart} <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-blue-600">{t.titleHighlight}</span>.
                </h1>
                <p class="text-lg text-text-muted dark:text-gray-400 max-w-xl mx-auto lg:mx-0 leading-relaxed">
                    {t.subtitle}
                </p>
                <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start pt-4">
                    <a href={BOOKING_URL} target="_blank" rel="noopener noreferrer" class="bg-text-main hover:bg-black text-white px-8 py-3.5 rounded-lg font-bold text-base transition-all shadow-xl hover:shadow-2xl flex items-center justify-center gap-2">
                        {t.ctaStart}
                        <span class="material-symbols-outlined text-[20px]" aria-hidden="true">rocket_launch</span>
                    </a>
                    <a href="#products" class="bg-white border border-gray-200 hover:bg-gray-50 text-text-main px-8 py-3.5 rounded-lg font-bold text-base transition-colors flex items-center justify-center gap-2">
                        {t.ctaView}
                        <span class="material-symbols-outlined text-[20px]" aria-hidden="true">grid_view</span>
                    </a>
                </div>
                <!-- Trust Badges -->
                <div class="pt-8 flex flex-col items-center lg:items-start gap-3">
                    <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider">{t.trust}</p>
                    <div class="flex flex-wrap justify-center lg:justify-start gap-6 opacity-60 grayscale hover:grayscale-0 transition-all duration-500">
                        <!-- Simple SVG placehodlers for logos -->
                        <div class="h-6 flex items-center font-bold text-gray-500"><span class="material-symbols-outlined mr-1">all_inclusive</span> n8n</div>
                        <div class="h-6 flex items-center font-bold text-gray-500"><span class="material-symbols-outlined mr-1">favorite</span> Lovable</div>
                        <div class="h-6 flex items-center font-bold text-gray-500"><span class="material-symbols-outlined mr-1">bolt</span> Zapier</div>
                        <div class="h-6 flex items-center font-bold text-gray-500"><span class="material-symbols-outlined mr-1">terminal</span> Python</div>
                        <div class="h-6 flex items-center font-bold text-gray-500"><span class="material-symbols-outlined mr-1">chat</span> WhatsApp</div>
                        <div class="h-6 flex items-center font-bold text-gray-500"><span class="material-symbols-outlined mr-1">send</span> Telegram</div>
                    </div>
                </div>
            </div>
            <!-- Hero Visual -->
            <div class="relative">
                <div class="absolute -inset-1 bg-gradient-to-r from-primary via-accent/40 to-primary/60 rounded-2xl blur opacity-30"></div>
                <div class="relative glass-card rounded-2xl p-6 shadow-soft dark:bg-surface-dark dark:border-gray-700">
                    <div class="aspect-[4/3] rounded-lg bg-background-soft dark:bg-gray-800 overflow-hidden relative border border-gray-100 dark:border-gray-700 group">
                        <!-- Abstract Automation Dashboard UI Mockup -->
                        <div class="absolute top-4 left-4 right-4 flex gap-2">
                            <div class="w-20 h-2 bg-gray-200 dark:bg-gray-600 rounded"></div>
                            <div class="w-12 h-2 bg-gray-200 dark:bg-gray-600 rounded"></div>
                        </div>
                        <!-- Flow Diagram Visualization -->
                        <div class="absolute inset-0 flex items-center justify-center">
                            <div class="relative w-full h-full p-8 flex flex-col justify-center items-center gap-6">
                                <!-- Node 1 -->
                                <div class="flex items-center gap-3 bg-white dark:bg-gray-700 p-3 rounded-lg shadow-sm border border-gray-100 dark:border-gray-600 z-10 w-48 animate-[float_4s_ease-in-out_infinite]">
                                    <div class="size-8 bg-blue-100 rounded flex items-center justify-center text-blue-600">
                                        <span class="material-symbols-outlined text-sm">mail</span>
                                    </div>
                                    <div class="flex flex-col gap-1 w-full">
                                        <div class="h-2 bg-gray-200 dark:bg-gray-500 rounded w-3/4"></div>
                                        <div class="h-1.5 bg-gray-100 dark:bg-gray-600 rounded w-1/2"></div>
                                    </div>
                                </div>
                                <!-- Connection Line -->
                                <div class="h-8 w-0.5 bg-gray-300 dark:bg-gray-600 relative overflow-hidden">
                                    <div class="absolute top-0 left-0 w-full h-1/2 bg-primary animate-[moveDown_1.5s_linear_infinite]"></div>
                                </div>
                                <!-- Node 2 -->
                                <div class="flex items-center gap-3 bg-white dark:bg-gray-700 p-3 rounded-lg shadow-sm border border-gray-100 dark:border-gray-600 z-10 w-48 animate-[float_4s_ease-in-out_infinite_1s]">
                                    <div class="size-8 bg-green-100 rounded flex items-center justify-center text-green-600">
                                        <span class="material-symbols-outlined text-sm">smart_toy</span>
                                    </div>
                                    <div class="flex flex-col gap-1 w-full">
                                        <div class="h-2 bg-gray-200 dark:bg-gray-500 rounded w-3/4"></div>
                                        <div class="h-1.5 bg-gray-100 dark:bg-gray-600 rounded w-1/2"></div>
                                    </div>
                                </div>
                                <!-- Connection Line -->
                                <div class="h-8 w-0.5 bg-gray-300 dark:bg-gray-600 relative overflow-hidden">
                                    <div class="absolute top-0 left-0 w-full h-1/2 bg-primary animate-[moveDown_1.5s_linear_infinite_0.5s]"></div>
                                </div>
                                <!-- Node 3 -->
                                <div class="flex items-center gap-3 bg-white dark:bg-gray-700 p-3 rounded-lg shadow-sm border border-gray-100 dark:border-gray-600 z-10 w-48 animate-[float_4s_ease-in-out_infinite_2s]">
                                    <div class="size-8 bg-purple-100 rounded flex items-center justify-center text-purple-600">
                                        <span class="material-symbols-outlined text-sm">database</span>
                                    </div>
                                    <div class="flex flex-col gap-1 w-full">
                                        <div class="h-2 bg-gray-200 dark:bg-gray-500 rounded w-3/4"></div>
                                        <div class="h-1.5 bg-gray-100 dark:bg-gray-600 rounded w-1/2"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>