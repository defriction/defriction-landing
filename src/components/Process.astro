---
import { ui } from '../i18n/ui';
const { lang = 'en' } = Astro.props;
const t = ui[lang as keyof typeof ui].process;
---
<section class="py-24 bg-white dark:bg-background-dark" id="process">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
            <h2 class="text-3xl font-extrabold text-text-main dark:text-white mb-4">{t.title}</h2>
            <p class="text-text-muted dark:text-gray-400">{t.subtitle}</p>
        </div>
        <div class="relative">
            <!-- Vertical Line -->
            <div class="absolute left-[28px] top-0 bottom-0 w-0.5 bg-gray-200 dark:bg-gray-800 md:left-1/2 md:-ml-0.5"></div>
            <!-- Step 1 -->
            <div class="relative flex flex-col md:flex-row items-center mb-12 group">
                <div class="flex-1 md:text-right md:pr-10 mb-4 md:mb-0">
                    <h3 class="text-lg font-bold text-text-main dark:text-white">{t.step1Title}</h3>
                    <p class="text-text-muted dark:text-gray-400 text-sm mt-1">{t.step1Desc}</p>
                </div>
                <div class="absolute left-0 md:relative md:left-auto flex items-center justify-center size-14 bg-white dark:bg-surface-dark border-4 border-primary/20 dark:border-primary/30 rounded-full z-10 shadow-sm">
                    <span class="material-symbols-outlined text-primary">lightbulb</span>
                </div>
                <div class="flex-1 md:pl-10 pl-16 md:block hidden">
                    <span class="text-xs font-bold text-primary bg-primary/10 px-3 py-1 rounded-full">{t.week1}</span>
                </div>
                <div class="pl-16 md:hidden w-full">
                    <span class="text-xs font-bold text-primary bg-primary/10 px-3 py-1 rounded-full">{t.week1}</span>
                </div>
            </div>
            <!-- Step 2 -->
            <div class="relative flex flex-col md:flex-row items-center mb-12 group">
                <div class="flex-1 md:text-right md:pr-10 mb-4 md:mb-0 md:block hidden">
                    <span class="text-xs font-bold text-accent bg-accent/10 dark:bg-accent/20 px-3 py-1 rounded-full">{t.week2}</span>
                </div>
                <div class="absolute left-0 md:relative md:left-auto flex items-center justify-center size-14 bg-white dark:bg-surface-dark border-4 border-accent/20 dark:border-accent/30 rounded-full z-10 shadow-sm">
                    <span class="material-symbols-outlined text-accent">design_services</span>
                </div>
                <div class="flex-1 md:pl-10 pl-16">
                    <h3 class="text-lg font-bold text-text-main dark:text-white">{t.step2Title}</h3>
                    <p class="text-text-muted dark:text-gray-400 text-sm mt-1">{t.step2Desc}</p>
                    <div class="md:hidden mt-2">
                        <span class="text-xs font-bold text-accent bg-accent/10 dark:bg-accent/20 px-3 py-1 rounded-full">{t.week2}</span>
                    </div>
                </div>
            </div>
            <!-- Step 3 -->
            <div class="relative flex flex-col md:flex-row items-center mb-12 group">
                <div class="flex-1 md:text-right md:pr-10 mb-4 md:mb-0">
                    <h3 class="text-lg font-bold text-text-main dark:text-white">{t.step3Title}</h3>
                    <p class="text-text-muted dark:text-gray-400 text-sm mt-1">{t.step3Desc}</p>
                </div>
                <div class="absolute left-0 md:relative md:left-auto flex items-center justify-center size-14 bg-white dark:bg-surface-dark border-4 border-blue-100 dark:border-blue-900/30 rounded-full z-10 shadow-sm">
                    <span class="material-symbols-outlined text-blue-500">construction</span>
                </div>
                <div class="flex-1 md:pl-10 pl-16 md:block hidden">
                    <span class="text-xs font-bold text-blue-500 bg-blue-100 dark:bg-blue-900/30 px-3 py-1 rounded-full">{t.week34}</span>
                </div>
                <div class="pl-16 md:hidden w-full">
                    <span class="text-xs font-bold text-blue-500 bg-blue-100 dark:bg-blue-900/30 px-3 py-1 rounded-full">{t.week34}</span>
                </div>
            </div>
            <!-- Step 4 -->
            <div class="relative flex flex-col md:flex-row items-center group">
                <div class="flex-1 md:text-right md:pr-10 mb-4 md:mb-0 md:block hidden">
                    <span class="text-xs font-bold text-green-500 bg-green-100 dark:bg-green-900/30 px-3 py-1 rounded-full">{t.ongoing}</span>
                </div>
                <div class="absolute left-0 md:relative md:left-auto flex items-center justify-center size-14 bg-white dark:bg-surface-dark border-4 border-green-100 dark:border-green-900/30 rounded-full z-10 shadow-sm">
                    <span class="material-symbols-outlined text-green-500">rocket</span>
                </div>
                <div class="flex-1 md:pl-10 pl-16">
                    <h3 class="text-lg font-bold text-text-main dark:text-white">{t.step4Title}</h3>
                    <p class="text-text-muted dark:text-gray-400 text-sm mt-1">{t.step4Desc}</p>
                    <div class="md:hidden mt-2">
                        <span class="text-xs font-bold text-green-500 bg-green-100 dark:bg-green-900/30 px-3 py-1 rounded-full">{t.ongoing}</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>