---
import { ui } from '../i18n/ui';

const { lang = 'en' } = Astro.props;
const t = ui[lang as keyof typeof ui].products;

const products = [
  {
    title: t.financeTitle,
    desc: t.financeDesc,
    link: 'https://t.me/defriction_expense_tracker_bot',
    // Aesthetic finance/tech image
    image: 'https://images.unsplash.com/photo-1554224155-6726b3ff858f?auto=format&fit=crop&q=80&w=800',
    alt: 'Finance Tracker Interface'
  },
  {
    title: t.inventoryTitle,
    desc: t.inventoryDesc,
    link: 'https://t.me/inventario_smart_bot',
    // Aesthetic warehouse/inventory image
    image: 'https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?auto=format&fit=crop&q=80&w=800',
    alt: 'Smart Inventory Management'
  },
  {
    title: t.comingSoonTitle,
    desc: t.comingSoonDesc,
    link: '#',
    // Aesthetic abstract/future image
    image: 'https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?auto=format&fit=crop&q=80&w=800',
    alt: 'Innovation Coming Soon',
    isComingSoon: true
  }
];
---

<section class="py-20 bg-gray-50" id="products">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">{t.title}</h2>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">{t.subtitle}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {products.map((product) => (
        <div class="bg-white rounded-2xl shadow-xl overflow-hidden hover:shadow-2xl transition-shadow duration-300 flex flex-col group">
          <div class="h-64 overflow-hidden relative">
            <div class="absolute inset-0 bg-black/10 group-hover:bg-black/0 transition-colors z-10"></div>
            <img 
              src={product.image} 
              alt={product.alt} 
              class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-500"
            />
          </div>
          <div class="p-8 flex-1 flex flex-col">
            <h3 class="text-2xl font-bold text-gray-900 mb-3">{product.title}</h3>
            <p class="text-gray-600 mb-6 flex-1">{product.desc}</p>
            {product.isComingSoon ? (
              <span class="inline-flex items-center justify-center px-6 py-3 border border-gray-200 text-base font-medium rounded-md text-gray-400 bg-gray-50 cursor-not-allowed w-full sm:w-auto self-start">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.384-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
                {t.comingSoonBtn}
              </span>
            ) : (
              <a 
                href={product.link} 
                target="_blank" 
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-white bg-primary hover:bg-primary/90 transition-colors w-full sm:w-auto self-start shadow-md hover:shadow-lg"
              >
                <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.628 0zm4.955 16.331c.22.136.38.366.417.638l.005.083a.826.826 0 0 1-.764.906l-.08.002a.86.86 0 0 1-.45-.13l-.06-.046-2.67-2.18-1.54 1.46c-.15.14-.36.21-.58.18l-.07-.02-.05-.02a.6.6 0 0 1-.36-.3l-.03-.07-1.33-4.37-3.73-1.16a.6.6 0 0 1-.02-1.14l.08-.02 9.49-3.64c.14-.05.29-.04.42.02l.07.04c.13.09.22.22.25.37l.004.06.002.02v.01l-1.44 9.32zm-6.2-4.6l.88 2.92.9-2.2-1.78-.72z"/></svg>
                {t.cta}
              </a>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>