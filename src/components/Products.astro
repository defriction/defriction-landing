---
import { ui } from '../i18n/ui';
import { productHref, type Lang } from '../lib/products';

const { lang = 'en' } = Astro.props;
const l = lang as Lang;
const t = ui[l].products;

const products = [
  {
    // Sinnet — tennis tournament manager (live). Links to its detail page.
    title: t.sinnetTitle,
    desc: t.sinnetDesc,
    image: '/sinnet-card.png',
    alt: 'Sinnet App — sigue los partidos en vivo, cancha por cancha',
    href: productHref(l, 'sinnet')
  },
  {
    title: t.financeTitle,
    desc: t.financeDesc,
    image: '/financial.jpg',
    alt: 'Finance Tracker Interface',
    href: productHref(l, 'finance-tracker')
  },
  {
    title: t.inventoryTitle,
    desc: t.inventoryDesc,
    image: 'https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?auto=format&fit=crop&q=80&w=800',
    alt: 'Smart Inventory Management',
    href: productHref(l, 'inventory')
  },
  {
    title: t.telegramTitle,
    desc: t.telegramDesc,
    image: '/telegram-card.svg',
    alt: 'Telegram',
    href: productHref(l, 'custom-automations')
  }
];
---

<section class="py-20 bg-gray-50 dark:bg-background-dark" id="products">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4">{t.title}</h2>
      <p class="text-xl text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">{t.subtitle}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {products.map((product) => {
        const media = product.image ? (
          <>
            <div class="absolute inset-0 bg-black/10 group-hover:bg-black/0 transition-colors z-10"></div>
            <img
              src={product.image}
              alt={product.alt}
              loading="lazy"
              class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-500"
            />
          </>
        ) : (
          <div class={`w-full h-full flex items-center justify-center bg-gradient-to-br ${product.gradient}`}>
            <span class="material-symbols-outlined text-white/90 text-8xl group-hover:scale-110 transition-transform duration-500" aria-hidden="true">{product.icon}</span>
          </div>
        );
        return (
        <div class="bg-white dark:bg-surface-dark rounded-2xl shadow-xl overflow-hidden hover:shadow-2xl transition-shadow duration-300 flex flex-col group">
          {product.href ? (
            <a href={product.href} class="block h-64 overflow-hidden relative">{media}</a>
          ) : (
            <div class="h-64 overflow-hidden relative">{media}</div>
          )}
          <div class="p-8 flex-1 flex flex-col">
            {product.href ? (
              <a href={product.href} class="block">
                <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-3 group-hover:text-primary transition-colors">{product.title}</h3>
              </a>
            ) : (
              <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-3">{product.title}</h3>
            )}
            <p class="text-gray-600 dark:text-gray-400 mb-6 flex-1">{product.desc}</p>
            {product.isComingSoon ? (
              <span class="inline-flex items-center justify-center px-6 py-3 border border-gray-200 dark:border-gray-700 text-base font-medium rounded-md text-gray-400 dark:text-gray-500 bg-gray-50 dark:bg-gray-800 cursor-not-allowed w-full sm:w-auto self-start">
                <span class="material-symbols-outlined text-[20px] mr-2" aria-hidden="true">schedule</span>
                {t.comingSoonBtn}
              </span>
            ) : product.href ? (
              <a
                href={product.href}
                class="inline-flex items-center justify-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-white bg-primary hover:bg-primary-dark transition-colors w-full sm:w-auto self-start shadow-md hover:shadow-lg group/cta"
              >
                {t.viewProduct}
                <span class="material-symbols-outlined text-[20px] ml-2 group-hover/cta:translate-x-0.5 transition-transform" aria-hidden="true">arrow_forward</span>
              </a>
            ) : product.contact ? (
              <a
                href={product.contact}
                class="inline-flex items-center justify-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-white bg-primary hover:bg-primary-dark transition-colors w-full sm:w-auto self-start shadow-md hover:shadow-lg group/cta"
              >
                {product.ctaLabel}
                <span class="material-symbols-outlined text-[20px] ml-2 group-hover/cta:translate-x-0.5 transition-transform" aria-hidden="true">arrow_forward</span>
              </a>
            ) : (
              <div class="flex flex-wrap gap-3">
                <a
                  href={product.telegram}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center justify-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-white bg-[#229ED9] hover:bg-[#1f91c7] transition-colors w-full sm:w-auto self-start shadow-md hover:shadow-lg"
                >
                  <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.628 0zm4.955 16.331c.22.136.38.366.417.638l.005.083a.826.826 0 0 1-.764.906l-.08.002a.86.86 0 0 1-.45-.13l-.06-.046-2.67-2.18-1.54 1.46c-.15.14-.36.21-.58.18l-.07-.02-.05-.02a.6.6 0 0 1-.36-.3l-.03-.07-1.33-4.37-3.73-1.16a.6.6 0 0 1-.02-1.14l.08-.02 9.49-3.64c.14-.05.29-.04.42.02l.07.04c.13.09.22.22.25.37l.004.06.002.02v.01l-1.44 9.32zm-6.2-4.6l.88 2.92.9-2.2-1.78-.72z"/></svg>
                  Telegram
                </a>
                {product.whatsapp && (
                  <a
                    href={product.whatsapp}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center justify-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-white bg-[#25D366] hover:bg-[#20bd5a] transition-colors w-full sm:w-auto self-start shadow-md hover:shadow-lg"
                  >
                    <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
                    WhatsApp
                  </a>
                )}
              </div>
            )}
          </div>
        </div>
        );
      })}
    </div>
  </div>
</section>
