---
import { ui } from '../i18n/ui';

const { lang = 'en' } = Astro.props;
const t = ui[lang as keyof typeof ui].faq;

const faqs = [
  { q: t.q1, a: t.a1 },
  { q: t.q2, a: t.a2 },
  { q: t.q3, a: t.a3 },
  { q: t.q4, a: t.a4 },
];
---

<section class="py-24 bg-background-soft dark:bg-background-dark">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-text-main dark:text-white">{t.title}</h2>
    </div>

    <div class="space-y-4">
      {faqs.map((faq) => (
        <details class="group bg-white dark:bg-surface-dark rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden transition-all duration-300 hover:shadow-md">
          <summary class="flex items-center justify-between p-6 cursor-pointer list-none">
            <h3 class="text-lg font-semibold text-text-main dark:text-white pr-4">{faq.q}</h3>
            <span class="transition-transform duration-300 group-open:rotate-180">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
              </svg>
            </span>
          </summary>
          <div class="px-6 pb-6 text-text-muted dark:text-gray-400 leading-relaxed animate-fade-in text-base" set:html={faq.a}>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  details > summary {
    list-style: none;
  }
  details > summary::-webkit-details-marker {
    display: none;
  }
</style>