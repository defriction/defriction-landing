---
import { ui } from '../i18n/ui';
const { lang = 'en' } = Astro.props;
const t = ui[lang as keyof typeof ui].nav;
---
<nav class="sticky top-0 z-50 w-full border-b border-[#e7eff3] dark:border-gray-800 bg-white/80 dark:bg-background-dark/80 backdrop-blur-md">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-20">
            <!-- Logo -->
            <div class="flex items-center gap-3">
                <div class="size-8 text-primary bg-primary/10 rounded-lg flex items-center justify-center">
                    <span class="material-symbols-outlined text-2xl">auto_mode</span>
                </div>
                <span class="text-xl font-bold tracking-tight text-text-main dark:text-white">AutoCreate</span>
            </div>
            <!-- Desktop Links -->
            <div class="hidden md:flex items-center gap-8">
                <a class="text-sm font-medium text-text-muted hover:text-primary transition-colors" href="#services">{t.services}</a>
                <a class="text-sm font-medium text-text-muted hover:text-primary transition-colors" href="#process">{t.process}</a>
                <a class="text-sm font-medium text-text-muted hover:text-primary transition-colors" href="#case-studies">{t.caseStudies}</a>
            </div>
            <!-- CTA -->
            <div class="flex items-center gap-4">
                <a href={lang === 'en' ? '/es' : '/'} class="text-sm font-bold text-text-muted hover:text-primary transition-colors">
                    {lang === 'en' ? 'ES' : 'EN'}
                </a>
                <button class="bg-primary hover:bg-primary-dark text-white text-sm font-bold py-2.5 px-6 rounded-lg transition-all shadow-lg hover:shadow-primary/30 flex items-center gap-2 group">
                    <span>{t.book}</span>
                    <span class="material-symbols-outlined text-[18px] group-hover:translate-x-0.5 transition-transform">arrow_forward</span>
                </button>
            </div>
        </div>
    </div>
</nav>