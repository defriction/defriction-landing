---
import { Image } from 'astro:assets';
import { ui } from '../i18n/ui';
import { productsAnchor, type Lang, type Product } from '../lib/products';

interface Props {
  product: Product;
  lang: Lang;
}

const { product, lang } = Astro.props;
const { data } = product;
const t = ui[lang].products;

// Per-product brand colors (fall back to the site theme tokens). Exposed as CSS
// vars so this generic component renders in each product's own identity.
const brand = data.brand ?? {
  color: 'var(--color-primary)',
  colorDark: 'var(--color-primary-dark)',
  accent: 'var(--color-accent)',
};
const brandStyle = [
  `--brand:${brand.color}`,
  `--brand-dark:${brand.colorDark}`,
  `--brand-accent:${brand.accent}`,
  `--brand-soft:color-mix(in srgb, ${brand.color} 12%, transparent)`,
  `--brand-accent-soft:color-mix(in srgb, ${brand.accent} 12%, transparent)`,
].join(';');

// Only render a CTA if its URL is a real link (placeholders use "#").
const isLink = (url?: string) => !!url && url !== '#';
const ext = (url: string) => url.startsWith('http');

// Button styling by variant.
const btnClass = (variant: string) => {
  if (variant === 'telegram') return 'bg-[#229ED9] hover:bg-[#1f91c7] text-white';
  if (variant === 'whatsapp') return 'bg-[#25D366] hover:bg-[#20bd5a] text-white';
  if (variant === 'secondary')
    return 'bg-white dark:bg-surface-dark border border-gray-200 dark:border-gray-700 text-text-main dark:text-white hover:bg-gray-50 dark:hover:bg-gray-800';
  return 'bg-[var(--brand)] hover:bg-[var(--brand-dark)] text-white';
};

// Hero/final buttons: generic `actions` if present, else Sinnet's `ctas`.
const actions = data.actions ?? [];
const ctas = data.ctas;
const mapped = actions.map((a) => ({ label: a.label[lang], url: a.url, variant: a.variant }));
const heroButtons =
  mapped.length > 0
    ? mapped
    : [
        ...(ctas && isLink(ctas.demoUrl) ? [{ label: t.requestDemo, url: ctas.demoUrl, variant: 'primary' }] : []),
        ...(ctas && isLink(ctas.liveUrl) ? [{ label: t.watchLive, url: ctas.liveUrl, variant: 'secondary' }] : []),
      ];
const finalButtons =
  mapped.length > 0
    ? mapped
    : [
        ...(ctas && isLink(ctas.demoUrl) ? [{ label: t.requestDemo, url: ctas.demoUrl, variant: 'primary' }] : []),
        ...(ctas && isLink(ctas.contactUrl) ? [{ label: ui[lang].nav.book, url: ctas.contactUrl, variant: 'secondary' }] : []),
      ];
---

<main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16" style={brandStyle}>
  <a href={productsAnchor(lang)} class="inline-flex items-center gap-1 text-sm font-medium text-[var(--brand)] hover:text-[var(--brand-dark)] mb-8">
    <span class="material-symbols-outlined text-[18px]" aria-hidden="true">arrow_back</span>
    {t.backToProducts}
  </a>

  <!-- Hero -->
  <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center mb-20">
    <div class="relative order-1 lg:order-2">
      <div class="absolute -inset-1 bg-gradient-to-r from-[var(--brand)] via-[var(--brand-accent)] to-[var(--brand)] rounded-2xl blur opacity-25"></div>
      {data.image ? (
        <Image src={data.image} alt={data.name[lang]} widths={[600, 1000]} sizes="(min-width: 1024px) 50vw, 100vw"
          class="relative w-full rounded-2xl shadow-xl object-cover" />
      ) : (
        <div class:list={["relative w-full aspect-[16/10] rounded-2xl shadow-xl flex items-center justify-center bg-gradient-to-br", data.gradient ?? 'from-primary to-blue-600']}>
          <span class="material-symbols-outlined text-white text-[7rem]" aria-hidden="true">{data.icon}</span>
        </div>
      )}
    </div>
    <div class="order-2 lg:order-1">
      <h1 class="text-4xl lg:text-5xl font-extrabold tracking-tight text-text-main dark:text-white mb-4">{data.name[lang]}</h1>
      <p class="text-xl font-semibold text-text-main dark:text-gray-100 mb-3">{data.hero.headline[lang]}</p>
      <p class="text-lg text-text-muted dark:text-gray-400 leading-relaxed mb-6">{data.hero.subtitle[lang]}</p>
      {data.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-8">
          {data.tags.map((tag) => (
            <span class="text-xs font-bold uppercase tracking-wider text-[var(--brand)] bg-[var(--brand-soft)] px-3 py-1 rounded-full">{tag[lang]}</span>
          ))}
        </div>
      )}
      {heroButtons.length > 0 && (
        <div class="flex flex-wrap gap-3">
          {heroButtons.map((b) => (
            <a href={b.url} target={ext(b.url) ? '_blank' : undefined} rel={ext(b.url) ? 'noopener noreferrer' : undefined}
              class:list={["inline-flex items-center justify-center px-6 py-3 text-base font-bold rounded-lg transition-all shadow-md hover:shadow-lg", btnClass(b.variant)]}>
              {b.label}
            </a>
          ))}
        </div>
      )}
    </div>
  </div>

  <!-- Overview -->
  <section class="mb-16">
    <h2 class="text-2xl font-bold text-text-main dark:text-white mb-4">{t.overviewTitle}</h2>
    <p class="text-lg text-text-muted dark:text-gray-400 leading-relaxed max-w-3xl">{data.overview[lang]}</p>
  </section>

  <!-- Audiences -->
  {data.audiences.length > 0 && (
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-text-main dark:text-white mb-6">{t.audiencesTitle}</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {data.audiences.map((a) => (
          <div class="flex items-start gap-3 bg-white dark:bg-surface-dark border border-gray-100 dark:border-gray-700 rounded-xl p-5 shadow-sm">
            <span class="material-symbols-outlined text-[var(--brand)] text-[22px] shrink-0" aria-hidden="true">group</span>
            <p class="text-text-muted dark:text-gray-300">{a[lang]}</p>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- Features: alternating rows, each backed by a screenshot (zig-zag) -->
  {data.features.length > 0 && (
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-text-main dark:text-white mb-10">{t.featuresTitle}</h2>
      <div class="space-y-16 lg:space-y-24">
        {data.features.map((f, i) => (
          f.image ? (
            <div class:list={["grid md:grid-cols-2 gap-8 lg:gap-12 items-center", i % 2 === 1 && "md:[&>*:first-child]:order-2"]}>
              <Image src={f.image} alt={f.title[lang]} widths={[640, 1024, 1600]} sizes="(min-width: 768px) 50vw, 100vw" loading="lazy"
                class="w-full rounded-2xl shadow-xl border border-gray-100 dark:border-gray-700" />
              <div>
                <div class="size-11 rounded-lg bg-[var(--brand-soft)] text-[var(--brand)] flex items-center justify-center mb-4">
                  <span class="material-symbols-outlined" aria-hidden="true">{f.icon}</span>
                </div>
                <h3 class="text-xl lg:text-2xl font-bold text-text-main dark:text-white mb-3">{f.title[lang]}</h3>
                <p class="text-text-muted dark:text-gray-400 leading-relaxed">{f.desc[lang]}</p>
              </div>
            </div>
          ) : (
            <div class="max-w-2xl">
              <div class="size-11 rounded-lg bg-[var(--brand-soft)] text-[var(--brand)] flex items-center justify-center mb-4">
                <span class="material-symbols-outlined" aria-hidden="true">{f.icon}</span>
              </div>
              <h3 class="text-xl lg:text-2xl font-bold text-text-main dark:text-white mb-3">{f.title[lang]}</h3>
              <p class="text-text-muted dark:text-gray-400 leading-relaxed">{f.desc[lang]}</p>
            </div>
          )
        ))}
      </div>
    </section>
  )}

  <!-- Support features -->
  {data.supportFeatures.length > 0 && (
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-text-main dark:text-white mb-5">{t.supportTitle}</h2>
      <div class="flex flex-wrap gap-3">
        {data.supportFeatures.map((s) => (
          <span class="inline-flex items-center gap-2 bg-gray-50 dark:bg-gray-800 text-text-muted dark:text-gray-300 text-sm font-medium px-4 py-2 rounded-full">
            <span class="material-symbols-outlined text-[var(--brand)] text-[18px]" aria-hidden="true">check</span>
            {s[lang]}
          </span>
        ))}
      </div>
    </section>
  )}

  <!-- Differentiators -->
  {data.differentiators.length > 0 && (
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-text-main dark:text-white mb-6">{t.differentiatorsTitle}</h2>
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {data.differentiators.map((d) => (
          <li class="flex items-start gap-3">
            <span class="material-symbols-outlined text-[var(--brand)] text-[22px] shrink-0" aria-hidden="true">verified</span>
            <span class="text-text-muted dark:text-gray-300 leading-relaxed">{d[lang]}</span>
          </li>
        ))}
      </ul>
    </section>
  )}

  <!-- Public portal invite (below the features) -->
  {isLink(ctas?.liveUrl) && (
    <section class="text-center mb-16">
      <p class="text-text-muted dark:text-gray-400 max-w-2xl mx-auto mb-5">{t.galleryPortalNote}</p>
      <a href={ctas.liveUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 px-8 py-3.5 text-base font-bold rounded-lg bg-[var(--brand)] hover:bg-[var(--brand-dark)] text-white transition-all shadow-md hover:shadow-lg">
        <span class="material-symbols-outlined text-[20px]" aria-hidden="true">public</span>
        {t.watchLive}
      </a>
    </section>
  )}

  <!-- Sober info blocks. Full width when only one is present. -->
  {(data.techNotes.length > 0 || data.honestScope.length > 0) && (
    <section class:list={["grid gap-8 mb-16 text-sm", data.techNotes.length > 0 && data.honestScope.length > 0 ? "md:grid-cols-2" : "grid-cols-1"]}>
      {data.techNotes.length > 0 && (
        <div class="bg-gray-50 dark:bg-gray-800/50 border border-gray-100 dark:border-gray-700 rounded-xl p-6">
          <h2 class="text-base font-bold text-text-main dark:text-white mb-3">{t.techNotesTitle}</h2>
          <ul class="flex flex-col gap-2">
            {data.techNotes.map((n) => <li class="text-text-muted dark:text-gray-400 leading-relaxed">{n[lang]}</li>)}
          </ul>
        </div>
      )}
      {data.honestScope.length > 0 && (
        <div class="bg-gray-50 dark:bg-gray-800/50 border border-gray-100 dark:border-gray-700 rounded-xl p-6">
          <h2 class="text-base font-bold text-text-main dark:text-white mb-3">{t.mvpScopeTitle}</h2>
          <ul class="flex flex-col gap-2">
            {data.honestScope.map((n) => <li class="text-text-muted dark:text-gray-400 leading-relaxed">{n[lang]}</li>)}
          </ul>
        </div>
      )}
    </section>
  )}

  <!-- Final CTA -->
  {finalButtons.length > 0 && (
    <section class="text-center bg-gradient-to-br from-[var(--brand-soft)] to-[var(--brand-accent-soft)] border border-[var(--brand-soft)] rounded-2xl px-6 py-12">
      <h2 class="text-2xl sm:text-3xl font-extrabold text-text-main dark:text-white mb-6">{t.finalCtaTitle}</h2>
      <div class="flex flex-wrap justify-center gap-3">
        {finalButtons.map((b) => (
          <a href={b.url} target={ext(b.url) ? '_blank' : undefined} rel={ext(b.url) ? 'noopener noreferrer' : undefined}
            class:list={["inline-flex items-center justify-center px-8 py-3.5 text-base font-bold rounded-lg transition-all shadow-md hover:shadow-lg", btnClass(b.variant)]}>
            {b.label}
          </a>
        ))}
      </div>
    </section>
  )}
</main>
