---
import { ui } from '../i18n/ui';
const { lang = 'en' } = Astro.props;
const t = ui[lang as keyof typeof ui].footer;
---
<footer class="bg-background-soft dark:bg-background-dark py-12 border-t border-gray-200 dark:border-gray-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row justify-between items-center gap-6">
        <div class="flex items-center gap-2">
            <div class="size-6 text-primary bg-primary/10 rounded flex items-center justify-center">
                <span class="material-symbols-outlined text-lg">auto_mode</span>
            </div>
            <span class="font-bold text-text-main dark:text-white">AutoCreate</span>
        </div>
        <div class="flex gap-8 text-sm font-medium text-text-muted dark:text-gray-400">
            <a class="hover:text-primary transition-colors" href="#">{t.privacy}</a>
            <a class="hover:text-primary transition-colors" href="#">{t.terms}</a>
            <a class="hover:text-primary transition-colors" href="#">Twitter</a>
            <a class="hover:text-primary transition-colors" href="#">LinkedIn</a>
        </div>
        <div class="text-sm text-gray-400">
            © {new Date().getFullYear()} defriction. {t.rights}
        </div>
    </div>
</footer>