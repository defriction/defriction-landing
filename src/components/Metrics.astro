---
import { ui } from '../i18n/ui';
const { lang = 'en' } = Astro.props;
const t = ui[lang as keyof typeof ui].metrics;
---
<section class="py-20 bg-primary text-white relative overflow-hidden">
    <div class="absolute top-0 right-0 w-1/2 h-full bg-white opacity-5 skew-x-12 transform translate-x-1/4"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
            <div class="p-6">
                <div class="text-5xl font-extrabold mb-2">20h+</div>
                <p class="text-white/80 font-medium">{t.saved}</p>
            </div>
            <div class="p-6 border-y md:border-y-0 md:border-x border-white/20">
                <div class="text-5xl font-extrabold mb-2">10x</div>
                <p class="text-white/80 font-medium">{t.faster}</p>
            </div>
            <div class="p-6">
                <div class="text-5xl font-extrabold mb-2">100%</div>
                <p class="text-white/80 font-medium">{t.flexibility}</p>
            </div>
        </div>
    </div>
</section>