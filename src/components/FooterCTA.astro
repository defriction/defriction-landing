---
import { ui } from '../i18n/ui';
const { lang = 'en' } = Astro.props;
const t = ui[lang as keyof typeof ui].footerCTA;
---
<section class="py-24 bg-white dark:bg-surface-dark border-t border-gray-100 dark:border-gray-800">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <span class="material-symbols-outlined text-6xl text-primary mb-6 animate-bounce">mail</span>
        <h2 class="text-4xl lg:text-5xl font-extrabold text-text-main dark:text-white mb-6 tracking-tight">
            {t.title}
        </h2>
        <p class="text-xl text-text-muted dark:text-gray-400 mb-10 max-w-2xl mx-auto">
            {t.subtitle}
        </p>
        <div class="flex flex-col sm:flex-row justify-center gap-4">
            <button class="bg-primary hover:bg-primary-dark text-white text-lg font-bold py-4 px-10 rounded-xl transition-all shadow-xl hover:shadow-primary/40 transform hover:-translate-y-1">
                {t.btn}
            </button>
        </div>
        <p class="mt-8 text-sm text-text-muted dark:text-gray-500">
            {t.note}
        </p>
    </div>
</section>