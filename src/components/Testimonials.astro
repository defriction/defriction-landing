---
import { ui } from '../i18n/ui';

const { lang = 'en' } = Astro.props;
const t = ui[lang as keyof typeof ui].testimonials;

const testimonials = [
  { quote: t.t1Quote, author: t.t1Author, role: t.t1Role },
  { quote: t.t2Quote, author: t.t2Author, role: t.t2Role },
  { quote: t.t3Quote, author: t.t3Author, role: t.t3Role },
];
---

<section class="py-24 bg-white dark:bg-background-dark border-t border-gray-100 dark:border-gray-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-text-main dark:text-white mb-4">{t.title}</h2>
      <p class="text-xl text-text-muted dark:text-gray-400 max-w-2xl mx-auto">{t.subtitle}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {testimonials.map((item) => (
        <div class="bg-gray-50 dark:bg-surface-dark p-8 rounded-2xl relative">
          <!-- Quote Icon -->
          <div class="absolute top-6 left-6 text-primary/20">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="currentColor">
              <path d="M14.017 21L14.017 18C14.017 16.8954 14.9124 16 16.017 16H19.017C19.5693 16 20.017 15.5523 20.017 15V9C20.017 8.44772 19.5693 8 19.017 8H15.017C14.4647 8 14.017 8.44772 14.017 9V11C14.017 11.5523 13.5693 12 13.017 12H12.017V5H22.017V15C22.017 18.3137 19.3307 21 16.017 21H14.017ZM5.0166 21L5.0166 18C5.0166 16.8954 5.91203 16 7.0166 16H10.0166C10.5689 16 11.0166 15.5523 11.0166 15V9C11.0166 8.44772 10.5689 8 10.0166 8H6.0166C5.46432 8 5.0166 8.44772 5.0166 9V11C5.0166 11.5523 4.56889 12 4.0166 12H3.0166V5H13.0166V15C13.0166 18.3137 10.3303 21 7.0166 21H5.0166Z" />
            </svg>
          </div>
          
          <p class="text-text-main dark:text-gray-300 relative z-10 mt-6 mb-6 text-lg italic leading-relaxed">
            "{item.quote}"
          </p>
          
          <div class="flex items-center gap-4">
            <div class="size-10 rounded-full bg-gradient-to-br from-primary to-accent flex items-center justify-center text-white font-bold text-sm">
              {item.author.charAt(0)}
            </div>
            <div>
              <h4 class="font-bold text-text-main dark:text-white">{item.author}</h4>
              <p class="text-sm text-text-muted dark:text-gray-500">{item.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>